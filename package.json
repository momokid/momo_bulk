{
  "name": "momo-bulk",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/client\"",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:client": "npm run dev --workspace=packages/client",
    "build": "npm run build --workspace=packages/client",
    "start": "npm run start --workspace=packages/server",
    "test": "concurrently \"npm run test --workspace=packages/server\" \"npm run test --workspace=packages/client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}