# ─── App ────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database ───────────────────────────────────────
# On XAMPP locally, host is localhost
# On cPanel, host is localhost but DB name and user
# will be prefixed with your cPanel account name
DB_HOST=localhost
DB_PORT=3306
DB_NAME=momo_bulk
DB_USER=root
DB_PASSWORD=

# ─── Auth ───────────────────────────────────────────
# Generate a strong random string for JWT_SECRET
# Never use a simple word here
JWT_SECRET=patrice_is_awesome_and_this_should_be_a_long_random_string
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# PIN hashing rounds — 10 is secure, don't go below
PIN_SALT_ROUNDS=10

# ─── MTN MoMo API ───────────────────────────────────
# Sandbox base URL for development
# Change to https://proxy.momoapi.mtn.com for production
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com

# From momodeveloper.mtn.com dashboard
MTN_SUBSCRIPTION_KEY=replace_with_your_subscription_key

# Generated during API user creation (we do this together)
MTN_API_USER=replace_with_your_api_user_uuid
MTN_API_KEY=replace_with_your_api_key
# Must be exactly 32 characters
ENCRYPTION_KEY=replace_with_32_character_string_here

# sandbox for dev, production for live
MTN_TARGET_ENVIRONMENT=sandbox

# Ghana cedi
MTN_CURRENCY=GHS

# Your agent MoMo number (sender number registered on MTN)
MTN_ACCOUNT_NUMBER=replace_with_your_momo_number

# ─── Client ─────────────────────────────────────────
# The URL your React app runs on during development
VITE_API_BASE_URL=http://localhost:5000